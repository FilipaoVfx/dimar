---
import Layout from '../layouts/Layout.astro';

const portfolioItems = [
    { title: "Evento Empresarial", category: "Empresarial", image: "/portfolio/01.jpg" },
    { title: "Fiesta Social", category: "Social", image: "/portfolio/02.jpg" },
    { title: "Show en Vivo", category: "Empresarial", image: "/portfolio/03.jpg" },
    { title: "Evento Institucional", category: "Institucional", image: "/portfolio/04.jpg" },
    { title: "Festival Cultural", category: "Cultural", image: "/portfolio/05.jpg" },
    { title: "Producción Técnica", category: "Empresarial", image: "/portfolio/06.jpg" },
];

const categories = ["Todos", "Empresarial", "Social", "Institucional", "Cultural"];
---

<Layout title="Portafolio">
    <div class="max-w-7xl mx-auto px-4 sm:px-8 py-24 min-h-screen">
        <div class="text-center mb-16">
            <span class="text-primary font-mono text-sm tracking-[0.4em] uppercase block mb-4 animate-fade-in-up">Nuestro trabajo</span>
            <h1 class="font-impact text-4xl md:text-6xl uppercase tracking-tighter text-on-surface mb-6 animate-fade-in-up animation-delay-200">Nuestro Portafolio</h1>
            <div class="h-px w-24 bg-primary mx-auto mb-8 animate-fade-in-up animation-delay-200"></div>
            <p class="text-on-surface-variant max-w-2xl mx-auto font-light leading-relaxed animate-fade-in-up animation-delay-200">
                Una selección de nuestros trabajos más destacados. Eventos que combinan diseño de vanguardia con una impecable ejecución.
            </p>
        </div>

        <!-- Filter Categories -->
        <div class="flex flex-wrap justify-center gap-3 mb-12 animate-fade-in-up animation-delay-400">
            {categories.map((cat, i) => (
                <button
                    class={`px-6 py-2 rounded-sm text-sm font-headline font-bold tracking-widest uppercase transition-colors ${i === 0 ? 'bg-surface-container-highest text-on-surface border border-outline-variant' : 'text-on-surface-variant hover:text-on-surface border border-transparent hover:border-outline-variant'}`}
                >
                    {cat}
                </button>
            ))}
        </div>

        <!-- Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 animate-fade-in-up animation-delay-400">
            {portfolioItems.map((item) => (
                <div class="group relative overflow-hidden rounded-sm cursor-pointer aspect-square bg-surface-container-low border border-surface-variant">
                    <img src={item.image} alt={item.title} class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-70 group-hover:opacity-100" loading="lazy" />
                    <div class="absolute inset-0 bg-gradient-to-t from-background via-background/20 to-transparent opacity-90 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="absolute bottom-0 left-0 p-6 translate-y-2 group-hover:translate-y-0 transition-all duration-500">
                        <span class="text-xs text-primary font-mono uppercase tracking-widest mb-2 block">{item.category}</span>
                        <h3 class="text-xl font-headline font-bold text-on-surface">{item.title}</h3>
                    </div>
                </div>
            ))}
        </div>
    </div>
</Layout>

<style>
    .animate-fade-in-up {
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        opacity: 0;
    }
    .animation-delay-200 { animation-delay: 200ms; }
    .animation-delay-400 { animation-delay: 400ms; }

    @keyframes fadeInUp {
        from { opacity: 0; transform: translateY(20px); }
        to   { opacity: 1; transform: translateY(0); }
    }
</style>
